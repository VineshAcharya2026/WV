rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }

    // Helper functions
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    // Users collection
    match /users/{userId} {
      allow read: if isSignedIn();
      allow create: if isOwner(userId) && 
        request.resource.data.keys().hasAll(['uid', 'email', 'preferredLanguage', 'createdAt']) &&
        request.resource.data.uid == request.auth.uid;
      allow update: if isOwner(userId) && 
        request.resource.data.diff(resource.data).affectedKeys().hasOnly(['preferredLanguage', 'displayName', 'photoURL']);
    }

    // Chats and Messages
    match /users/{userId}/messages/{messageId} {
        allow read, list: if isOwner(userId);
        allow create: if isOwner(userId);
        allow delete: if isOwner(userId);
    }
  }
}
